---
import githubSvg from "../github.svg";
import linkedinSvg from "../linkedin.svg";

const { title } = Astro.props;

const menus = [
  { name: "articles", href: "/articles" },
  { name: "references", href: "/references" },
  { name: "tags", href: "/tags" },
];

const socials = [
  { href: "//github.com/raeperd/", src: githubSvg },
  { href: "//linkedin.com/in/raeperd/", src: linkedinSvg },
];
---

<!DOCTYPE html>
<html class="h-full" lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body
    class="flex flex-col h-full bg-slate-900 text-slate-200 max-w-screen-2xl m-auto"
  >
    <header class="flex justify-between text-xl my-5 md:mx-5">
      <nav class="flex">
        <a href="/" class="font-bold text-xl md:text-2xl hover:underline mx-3">
          raeperd.github.io
        </a>
        <nav class="flex items-center">
          {
            menus.map((menu) => (
              <a href={menu.href} class="hover:underline mx-3">
                {menu.name}
              </a>
            ))
          }
        </nav>
      </nav>
      <nav class="hidden md:flex justify-center">
        {
          socials.map((social) => (
            <a href={social.href} target="_blank" class="invert mx-2">
              <img src={social.src} />
            </a>
          ))
        }
      </nav>
    </header>
    <main
      class="flex flex-col justify-center items-center max-w-screen-xl mx-auto px-8 xl:px-0"
    >
      <slot />
    </main>
    <footer class="flex justify-center items-center mt-auto mb-3 text-sm">
      <p class="mx-1">
        &copy;
        {new Date().getFullYear()}
        <a href="/" class="hover:underline">raeperd.github.io</a>
      </p>
      <p>
        Powered by
        <a href="https://astro.build/" target="_blank" class="hover:underline">
          Astro</a
        >
      </p>
    </footer>
  </body>
</html>
