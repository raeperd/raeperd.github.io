---
import Layout from "@layouts/Layout.astro";
import PostCardContainer from "src/components/PostCardContainer.astro";
import byFrontMatterDate from "src/functions/byFrontMatterDate";

const posts = (await Astro.glob("./**/*.md")).sort(byFrontMatterDate);
---

<Layout title="raeperd.github.io">
  <PostCardContainer posts={posts} />
</Layout>
